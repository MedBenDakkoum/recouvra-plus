<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <main class="max-w-7xl mx-auto px-4 py-12 space-y-12">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4"><a href="/invoices"
                        class="text-blue-500 hover:text-blue-700 font-bold"><i class="fas fa-arrow-left"></i> Retour</a>
                    <h1 class="text-3xl font-extrabold text-slate-800" id="invTitle">...</h1>
                </div>
                <div class="flex space-x-2"><button onclick="editModal.classList.toggle('hidden')"
                        class="px-4 py-2 bg-blue-600 text-white rounded-lg shadow font-bold text-xs uppercase transition hover:bg-blue-700">Modifier</button>
                    <div id="invStatusBadge"></div>
                </div>
            </div>
            <div id="editModal" class="hidden glass p-8 rounded-2xl shadow-xl border border-slate-200">
                <form id="editForm" class="grid sm:grid-cols-2 gap-4">
                    <div class="sm:col-span-2"><label
                            class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1">Numéro de
                            Facture</label><input name="invoiceNumber" id="editNum" required
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div><label
                            class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1">Montant</label><input
                            name="amount" type="number" id="editAmount" required
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div><label
                            class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1">Échéance</label><input
                            name="dueDate" type="date" id="editDate" required
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    </div>
                    <div class="sm:col-span-2"><label
                            class="text-[10px] font-bold text-slate-400 uppercase tracking-widest pl-1">Statut</label><select
                            name="status" id="editStatus"
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                            <option value="pending">En attente</option>
                            <option value="overdue">En retard</option>
                            <option value="partial">Partiel</option>
                            <option value="paid">Payée</option>
                        </select></div>
                    <button
                        class="px-6 py-2 bg-emerald-600 text-white rounded-lg font-bold sm:col-span-2">Enregistrer</button>
                </form>
            </div>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="glass p-8 rounded-3xl border border-slate-100">
                    <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6 border-b pb-2">Infos
                        Facture</h2>
                    <div id="invInfo" class="grid grid-cols-2 gap-4"></div>
                </div>
                <div class="glass p-8 rounded-3xl border border-slate-100">
                    <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-4 border-b pb-2">Paiement
                    </h2>
                    <form id="payForm" class="space-y-4">
                        <input name="amount" type="number" placeholder="Montant" required
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                        <select name="paymentMethod"
                            class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                            <option value="virement">Virement</option>
                            <option value="cheque">Chèque</option>
                            <option value="carte">Carte</option>
                            <option value="especes">Espèces</option>
                        </select>
                        <button
                            class="w-full py-3 bg-emerald-600 text-white rounded-xl font-bold hover:bg-emerald-700 transition">Valider
                            Paiement</button>
                    </form>
                </div>
            </div>
            <div class="space-y-6">
                <h2 class="text-2xl font-bold text-slate-800">Historique</h2>
                <div class="glass rounded-2xl overflow-hidden border border-slate-100 shadow-sm">
                    <table class="w-full text-left text-sm bg-white">
                        <thead class="bg-slate-50 border-b border-slate-100">
                            <tr class="text-slate-500 font-medium uppercase">
                                <th class="px-6 py-4">Date</th>
                                <th class="px-6 py-4">Méthode</th>
                                <th class="px-6 py-4 text-right">Montant</th>
                            </tr>
                        </thead>
                        <tbody id="payTable" class="divide-y divide-slate-50 font-medium"></tbody>
                    </table>
                </div>
            </div>
        </main>
        <%- include('partials/api-helper') %>
            <script>
                const invoiceId = '<%= invoiceId %>';
                const render = async () => {
                    const resInv = await apiCall(`/invoices/${invoiceId}`); const i = resInv.data;
                    invTitle.innerText = `Facture #${i.invoiceNumber}`;
                    invStatusBadge.innerHTML = `<span class="px-3 py-1 rounded-full text-[10px] font-extrabold uppercase ${i.status === 'paid' ? 'bg-emerald-100 text-emerald-600' : 'bg-red-100 text-red-600'}">${i.status}</span>`;
                    invInfo.innerHTML = `<div><div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Montant</div><div class="font-bold text-xl text-blue-600">${i.amount} TND</div></div><div><div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Échéance</div><div class="font-bold">${new Date(i.dueDate).toLocaleDateString()}</div></div><div class="col-span-2"><div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Client</div><div class="font-bold border-t pt-2 mt-2">${i.client?.name || 'Inconnu'}</div></div>`;
                    editNum.value = i.invoiceNumber; editAmount.value = i.amount; editDate.value = i.dueDate.split('T')[0]; editStatus.value = i.status;
                    const resPay = await apiCall('/payments'); const pays = resPay.data || [];
                    payTable.innerHTML = pays.filter(p => (p.invoice?._id || p.invoice) === invoiceId).map(p => `<tr class="hover:bg-blue-50 transition-colors"><td class="px-6 py-4 font-bold">${new Date(p.paymentDate).toLocaleDateString()}</td><td class="px-6 py-4 text-slate-600 uppercase text-[10px]">${p.paymentMethod}</td><td class="px-6 py-4 text-right font-extrabold text-emerald-600">+ ${p.amount} TND</td></tr>`).join('') || '<tr><td colspan="3" class="px-6 py-8 text-center text-slate-400">Aucun paiement</td></tr>';
                };
                editForm.onsubmit = async (e) => { e.preventDefault(); await apiCall(`/invoices/${invoiceId}`, 'PUT', Object.fromEntries(new FormData(editForm))); editModal.classList.add('hidden'); render(); };
                payForm.onsubmit = async (e) => { e.preventDefault(); await apiCall('/payments', 'POST', { ...Object.fromEntries(new FormData(payForm)), invoice: invoiceId }); payForm.reset(); render(); };
                render();
            </script>
            <%- include('partials/footer') %>