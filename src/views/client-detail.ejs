<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <main class="max-w-7xl mx-auto px-4 py-12 space-y-12">
            <div class="flex items-center justify-between">
                <div class="flex items-center space-x-4"><a href="/clients"
                        class="text-blue-500 hover:text-blue-700 transition font-bold"><i class="fas fa-arrow-left"></i>
                        Retour</a>
                    <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight" id="clientTitle">...</h1>
                </div><button onclick="editModal.classList.toggle('hidden')"
                    class="px-6 py-2 bg-blue-600 text-white rounded-xl shadow-lg hover:bg-blue-700 transition font-bold">Modifier</button>
            </div>
            <div class="grid md:grid-cols-2 gap-8">
                <div class="glass p-8 rounded-3xl shadow-sm border border-slate-100">
                    <h2 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">Informations Générales
                    </h2>
                    <div id="clientInfo" class="space-y-4"></div>
                </div>
                <div
                    class="glass p-8 rounded-3xl border border-slate-100 flex items-center justify-center font-bold text-slate-300 uppercase text-[10px]">
                    Stats Client (Prochainement)</div>
            </div>
            <div id="editModal" class="hidden glass p-8 rounded-2xl shadow-xl border border-slate-200">
                <form id="editForm" class="grid sm:grid-cols-2 gap-4">
                    <input name="name" id="editName" placeholder="Nom" required
                        class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    <input name="email" id="editEmail" placeholder="Email" required
                        class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    <input name="phone" id="editPhone" placeholder="Téléphone"
                        class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    <input name="company" id="editCompany" placeholder="Société"
                        class="px-4 py-2 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none">
                    <button class="px-6 py-2 bg-emerald-500 text-white rounded-lg font-bold sm:col-span-2">Enregistrer
                        les modifications</button>
                </form>
            </div>
            <div class="space-y-6">
                <h2 class="text-2xl font-bold text-slate-800">Factures</h2>
                <div class="glass rounded-2xl overflow-hidden border border-slate-100">
                    <table class="w-full text-left text-sm bg-white">
                        <thead class="bg-slate-50 border-b border-slate-100">
                            <tr class="text-slate-500 font-medium uppercase">
                                <th class="px-6 py-4">Numéro</th>
                                <th class="px-6 py-4 text-right">Montant</th>
                                <th class="px-6 py-4">Statut</th>
                            </tr>
                        </thead>
                        <tbody id="invoiceTable" class="divide-y divide-slate-50"></tbody>
                    </table>
                </div>
            </div>
        </main>
        <%- include('partials/api-helper') %>
            <script>
                const clientId = '<%= clientId %>';
                const render = async () => {
                    const res = await apiCall(`/clients/${clientId}`); const c = res.data;
                    clientTitle.innerText = c.name;
                    clientInfo.innerHTML = `<div><div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Société</div><div class="font-bold text-lg">${c.company || '-'}</div></div><div><div class="text-[10px] text-slate-400 font-bold uppercase mb-1">Email / Tel</div><div class="font-bold">${c.email} / ${c.phone || '-'}</div></div>`;
                    ['name', 'email', 'phone', 'company'].forEach(f => document.getElementById(`edit${f.charAt(0).toUpperCase() + f.slice(1)}`).value = c[f] || '');
                    const resInv = await apiCall('/invoices'); const invoices = resInv.data || [];
                    invoiceTable.innerHTML = invoices.filter(i => (i.client?._id || i.client) === clientId).map(i => `<tr class="hover:bg-blue-50 transition-colors"><td class="px-6 py-4 font-bold">#${i.invoiceNumber}</td><td class="px-6 py-4 text-right font-extrabold text-blue-600">${i.amount} TND</td><td class="px-6 py-4"><span class="px-2 py-1 rounded text-[10px] font-bold uppercase ${i.status === 'paid' ? 'bg-emerald-100 text-emerald-600' : 'bg-red-100 text-red-600'}">${i.status}</span></td></tr>`).join('') || '<tr><td colspan="3" class="px-6 py-12 text-center text-slate-400 font-bold uppercase text-xs">Aucune facture</td></tr>';
                };
                editForm.onsubmit = async (e) => { e.preventDefault(); await apiCall(`/clients/${clientId}`, 'PUT', Object.fromEntries(new FormData(editForm))); editModal.classList.add('hidden'); render(); };
                render();
            </script>
            <%- include('partials/footer') %>