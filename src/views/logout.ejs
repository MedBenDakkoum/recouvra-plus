<%- include('partials/head') %>
    <main class="flex items-center justify-center min-h-[80vh] px-4">
        <div class="max-w-md w-full text-center p-8">
            <div
                class="w-20 h-20 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6 text-emerald-500 text-3xl">
                <i class="fas fa-sign-out-alt"></i></div>
            <h1 class="text-3xl font-bold text-slate-800">Déconnexion en cours...</h1>
            <p class="text-slate-500 mt-2">Nous sécurisons votre session.</p>
        </div>
    </main>
    <script>
        localStorage.removeItem('token'); localStorage.removeItem('user');
        setTimeout(() => window.location.href = '/login', 1500);
    </script>
    <%- include('partials/footer') %>