<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <main class="max-w-7xl mx-auto px-4 py-12 space-y-12">
            <div class="flex justify-between items-end">
                <h1 class="text-3xl font-bold text-slate-900">Gestion des Factures</h1><button
                    onclick="invoiceModal.classList.toggle('hidden')"
                    class="px-6 py-2 bg-blue-600 text-white rounded-xl shadow-lg hover:bg-blue-700 transition font-bold">+
                    Créer Facture</button>
            </div>
            <div id="invoiceModal" class="hidden glass p-8 rounded-2xl shadow-xl border border-slate-200">
                <form id="invoiceForm" class="grid sm:grid-cols-2 gap-4">
                    <input name="invoiceNumber" placeholder="Numéro Facture" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <select name="client" id="clientSelect" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500"></select>
                    <input name="amount" type="number" placeholder="Montant" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <input name="dueDate" type="date" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <select name="status"
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                        <option value="pending">En attente</option>
                        <option value="overdue">En retard</option>
                        <option value="paid">Payée</option>
                    </select>
                    <button
                        class="px-6 py-2 bg-emerald-500 text-white rounded-lg shadow hover:bg-emerald-600 transition font-bold sm:col-span-2">Enregistrer
                        Facture</button>
                </form>
            </div>
            <div class="glass rounded-2xl overflow-hidden border border-slate-100 shadow-sm">
                <table class="w-full text-left text-sm bg-white">
                    <thead class="bg-slate-50 border-b border-slate-100">
                        <tr class="text-slate-500 font-medium uppercase">
                            <th class="px-6 py-4">Numéro</th>
                            <th class="px-6 py-4">Client</th>
                            <th class="px-6 py-4">Montant</th>
                            <th class="px-6 py-4">Échéance</th>
                            <th class="px-6 py-4">Statut</th>
                            <th class="px-6 py-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="invoiceTable" class="divide-y divide-slate-50 font-medium text-slate-800"></tbody>
                </table>
            </div>
        </main>
        <%- include('partials/api-helper') %>
            <script>
                const render = async () => {
                    const resCli = await apiCall('/clients');
                    const clients = resCli.data || [];
                    clientSelect.innerHTML = clients.map(c => `<option value="${c._id}">${c.name}</option>`).join('');
                    const resInv = await apiCall('/invoices');
                    const invoices = resInv.data || [];
                    invoiceTable.innerHTML = invoices.map(i => `<tr class="hover:bg-blue-50 transition-colors"><td class="px-6 py-4 font-bold">${i.invoiceNumber}</td><td class="px-6 py-4 text-slate-600">${i.client?.name || 'Inconnu'}</td><td class="px-6 py-4 font-extrabold text-blue-600">${i.amount} ${i.currency || 'TND'}</td><td class="px-6 py-4">${new Date(i.dueDate).toLocaleDateString()}</td><td class="px-6 py-4"><span class="px-3 py-1 rounded-full text-xs font-bold uppercase ${i.status === 'paid' ? 'bg-emerald-100 text-emerald-600' : 'bg-red-100 text-red-600'}">${i.status}</span></td><td class="px-6 py-4"><a href="/invoices/${i._id}" class="text-blue-500 hover:underline">Détails</a></td></tr>`).join('') || '<tr><td colspan="6" class="px-6 py-12 text-center text-slate-400 font-bold uppercase text-xs">Aucune facture trouvée</td></tr>';
                };
                invoiceForm.onsubmit = async (e) => { e.preventDefault(); await apiCall('/invoices', 'POST', Object.fromEntries(new FormData(invoiceForm))); invoiceForm.reset(); invoiceModal.classList.add('hidden'); render(); };
                render();
            </script>
            <%- include('partials/footer') %>