<%- include('partials/head') %>
    <%- include('partials/nav') %>
        <main class="max-w-7xl mx-auto px-4 py-12 space-y-12">
            <div class="flex justify-between items-end">
                <h1 class="text-3xl font-bold text-slate-900">Gestion des Clients</h1><button
                    onclick="clientModal.classList.toggle('hidden')"
                    class="px-6 py-2 bg-blue-600 text-white rounded-xl shadow-lg hover:bg-blue-700 transition font-bold">+
                    Ajouter Client</button>
            </div>
            <div id="clientModal" class="hidden glass p-8 rounded-2xl shadow-xl border border-slate-200">
                <form id="clientForm" class="grid sm:grid-cols-2 gap-4">
                    <input name="name" placeholder="Nom" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <input name="email" placeholder="Email" required
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <input name="phone" placeholder="Téléphone"
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <input name="company" placeholder="Société"
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <input name="siret" placeholder="SIRET"
                        class="px-4 py-2 border rounded-lg outline-none focus:ring-2 focus:ring-blue-500">
                    <button
                        class="px-6 py-2 bg-emerald-500 text-white rounded-lg shadow hover:bg-emerald-600 transition font-bold sm:col-span-2">Enregistrer
                        le client</button>
                </form>
            </div>
            <div class="glass rounded-2xl overflow-hidden border border-slate-100 shadow-sm">
                <table class="w-full text-left text-sm">
                    <thead class="bg-slate-50 border-b border-slate-100">
                        <tr class="text-slate-500 font-medium uppercase">
                            <th class="px-6 py-4">Nom / Société</th>
                            <th class="px-6 py-4">Contact</th>
                            <th class="px-6 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody id="clientTable" class="divide-y divide-slate-50 font-medium text-slate-800"></tbody>
                </table>
            </div>
        </main>
        <%- include('partials/api-helper') %>
            <script>
                const render = async () => {
                    const res = await apiCall('/clients'); const clients = res.data || [];
                    clientTable.innerHTML = clients.map(c => `<tr class="hover:bg-blue-50 transition-colors"><td class="px-6 py-4">${c.name} <br/><span class="text-slate-400 font-normal text-xs uppercase">${c.company || '-'}</span></td><td class="px-6 py-4">${c.email}<br/><span class="text-slate-400 font-normal text-xs">${c.phone || '-'}</span></td><td class="px-6 py-4 space-x-3 text-right"><a href="/clients/${c._id}" class="text-blue-500 hover:underline text-[10px] font-bold uppercase">Détails</a><button onclick="deactivateClient('${c._id}')" class="text-amber-500 hover:text-amber-700 text-[10px] font-bold uppercase">Désactiver</button><button onclick="deleteClient('${c._id}')" class="text-red-500 hover:text-red-700 text-[10px] font-bold uppercase">Supprimer</button></td></tr>`).join('') || '<tr><td colspan="3" class="px-8 py-12 text-center text-slate-400 uppercase text-xs">Aucun client actif trouvé</td></tr>';
                };
                clientForm.onsubmit = async (e) => { e.preventDefault(); await apiCall('/clients', 'POST', Object.fromEntries(new FormData(clientForm))); clientForm.reset(); clientModal.classList.add('hidden'); render(); };
                window.deactivateClient = async (id) => { if (confirm('Désactiver ce client ? Il ne sera plus visible dans la liste.')) { await apiCall(`/clients/${id}/deactivate`, 'PATCH'); render(); } };
                window.deleteClient = async (id) => { if (confirm('SUPPRIMER DÉFINITIVEMENT ce client ? Cette action est irréversible.')) { await apiCall(`/clients/${id}`, 'DELETE'); render(); } };
                render();
            </script>
            <%- include('partials/footer') %>